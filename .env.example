# Square API Configuration
# Get these from https://developer.squareup.com/apps

# Frontend (exposed to browser via Vite)
VITE_SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXX
VITE_SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXX
VITE_SQUARE_ENVIRONMENT=sandbox

# Server-side only
SQUARE_ACCESS_TOKEN=EAAAl...your_sandbox_access_token
SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXX
SQUARE_ENVIRONMENT=sandbox

# Admin (protects lead dashboard + Square seed/cache)
ADMIN_SECRET=replace-with-strong-secret
